# Copy to <repo>/.config/terraform/components/runners/amd64.tfvars (not committed; keep secrets local).
# First line of the live file: # homelab-config: terraform/components/runners/amd64
# Docker provider for AMD64 pool hosts (standalone docker_container, not Swarm).
# Shared by gha-runner-amd64 and jenkins-agent-amd64 pipelines.

swarm_docker_provider_config = {
  docker = {
    host = "ssh://USER@AMD64_POOL_HOST"
    ssh_opts = [
      "-o", "StrictHostKeyChecking=accept-new",
      "-o", "UserKnownHostsFile=/path/to/known_hosts",
      "-i", "/path/to/id_ed25519",
    ]
  }

  registry_auths = [
    {
      address  = "ghcr.io"
      username = "GITHUB_USER_OR_ORG"
      password = "GITHUB_PAT_WITH_PACKAGES_READ"
    },
    {
      address  = "zot.nodadyoushutup.com"
      username = "homelab"
      password = "ZOT_REGISTRY_PASSWORD"
    },
  ]
}
