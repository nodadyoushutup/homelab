  "panels": [
    {
      "id": 1,
      "title": "Avg disk utilization",
      "description": "Unified across TrueNAS versions: legacy disk_util.* (24.x) or truenas_disk_stats.busy.* (newer SCALE).",
      "type": "stat",
      "datasource": { "type": "graphite", "uid": "graphite" },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "target": "alias(maxSeries(averageSeries(aliasByNode(truenas.$host.disk_util.*.utilization, 3)), averageSeries(truenas.$host.truenas_disk_stats.busy.*.busy)), 'util %')"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "CPU usage",
      "description": "Unified across TrueNAS versions: truenas_cpu_usage (newer SCALE) or legacy cpu.* counters (24.x).",
      "type": "stat",
      "datasource": { "type": "graphite", "uid": "graphite" },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "target": "alias(maxSeries(averageSeries(truenas.$host.truenas_cpu_usage.cpu.cpu*), scale(divideSeries(sumSeries(truenas.$host.cpu.*.{user,system,iowait,irq,softirq,nice,steal}), sumSeries(truenas.$host.cpu.*.*)), 100)), 'cpu %')"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Memory used",
      "description": "Unified across TrueNAS versions: truenas_meminfo (newer SCALE) or legacy system.ram.* (24.x).",
      "type": "stat",
      "datasource": { "type": "graphite", "uid": "graphite" },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "target": "alias(maxSeries(scale(divideSeries(diffSeries(truenas.$host.truenas_meminfo.total.total, truenas.$host.truenas_meminfo.available.available), truenas.$host.truenas_meminfo.total.total), 100), averageSeries(asPercent(groupByNode(truenas.$host.system.ram.used, 1, 'sum'), groupByNode(truenas.$host.system.ram.*, 1, 'sum')))), 'mem %')"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "CPU & memory",
      "description": "Same unified CPU and memory queries as the stat row above.",
      "type": "timeseries",
      "datasource": { "type": "graphite", "uid": "graphite" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "target": "alias(maxSeries(averageSeries(truenas.$host.truenas_cpu_usage.cpu.cpu*), scale(divideSeries(sumSeries(truenas.$host.cpu.*.{user,system,iowait,irq,softirq,nice,steal}), sumSeries(truenas.$host.cpu.*.*)), 100)), 'cpu %')"
        },
        {
          "refId": "B",
          "target": "alias(maxSeries(scale(divideSeries(diffSeries(truenas.$host.truenas_meminfo.total.total, truenas.$host.truenas_meminfo.available.available), truenas.$host.truenas_meminfo.total.total), 100), averageSeries(asPercent(groupByNode(truenas.$host.system.ram.used, 1, 'sum'), groupByNode(truenas.$host.system.ram.*, 1, 'sum')))), 'mem %')"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 1,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 5,
      "title": "Disk activity",
      "description": "Unified disk busy % and aggregate write ops across TrueNAS versions.",
      "type": "timeseries",
      "datasource": { "type": "graphite", "uid": "graphite" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 13 },
      "targets": [
        {
          "refId": "A",
          "target": "alias(maxSeries(averageSeries(aliasByNode(truenas.$host.disk_busy.*.busy, 3)), averageSeries(truenas.$host.truenas_disk_stats.busy.*.busy)), 'busy %')"
        },
        {
          "refId": "B",
          "target": "alias(absolute(maxSeries(sumSeries(truenas.$host.disk_ops.*.writes), sumSeries(truenas.$host.truenas_disk_stats.*.writes))), 'writes/s')"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 1,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "busy %" },
            "properties": [{ "id": "unit", "value": "percent" }]
          },
          {
            "matcher": { "id": "byName", "options": "writes/s" },
            "properties": [{ "id": "unit", "value": "ops" }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    }
  ]
}
