  "templating": {
    "list": [
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": { "type": "graphite", "uid": "graphite" },
        "definition": "truenas.*",
        "query": "truenas.*",
        "includeAll": false,
        "multi": false,
