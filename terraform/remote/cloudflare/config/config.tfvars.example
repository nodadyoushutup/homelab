# Example only — copy to /mnt/eapp/config/cloudflare/config.tfvars (or pass via --tfvars).
# Do not commit real api_token values.
# To drop DNS for retired standalone code MCPs only: edit your live tfvars and delete those
# `records` rows — see docs/workflows/edge-dns-and-nginx-proxy.md (section "Retired standalone code MCPs").

provider_config = {
  cloudflare = {
    api_token = "replace-with-cloudflare-api-token"
  }
}

zone_id = "replace-with-zone-id"

records = [
  {
    key     = "example_app_a"
    name    = "app.example.com"
    content = "192.0.2.10" # RFC1918 for anything not meant to be reachable from the public internet
    ttl     = 1
    proxied = false
  },
  # Only apps intentionally exposed on WAN should use your public IP in `content`;
  # align FortiGate VIPs / firewall with that same allowlist (see docs/workflows/edge-dns-and-nginx-proxy.md).
]
