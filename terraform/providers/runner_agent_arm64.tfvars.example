# Copy to CONFIG_DIR/terraform/providers/runner_agent_arm64.tfvars (not committed).
# Docker provider for the ARM64 runner/agent pool (standalone docker_container, not Swarm).
# Shared by gha-runner-arm64 and jenkins-agent-arm64 pipelines.

swarm_docker_provider_config = {
  docker = {
    host = "ssh://USER@ARM64_POOL_HOST"
    ssh_opts = [
      "-o", "StrictHostKeyChecking=accept-new",
      "-o", "ConnectTimeout=15",
      "-o", "ServerAliveInterval=10",
      "-o", "ServerAliveCountMax=3",
      "-o", "UserKnownHostsFile=/path/to/known_hosts",
      "-i", "/path/to/id_ed25519",
    ]
  }

  registry_auths = [
    {
      address  = "ghcr.io"
      username = "GITHUB_USER_OR_ORG"
      password = "GITHUB_PAT_WITH_PACKAGES_READ"
    },
  ]
}
