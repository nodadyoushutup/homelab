# Copy to CONFIG_DIR/terraform/providers/docker_amd64.tfvars (not committed).
# Optional: only pipelines/terraform/swarm/gha-runner-amd64/app.sh merges this after docker_arm64.tfvars.
# Sets `swarm_docker_provider_config` for the AMD64 pool host (standalone docker_container, not Swarm).
# Merged last by pipelines/terraform/swarm/gha-runner-amd64/app.sh (replaces docker_arm64.tfvars for this stack).
# Include `docker` (pool SSH host) and `registry_auths` as in docker_arm64.tfvars.

swarm_docker_provider_config = {
  docker = {
    host = "ssh://USER@AMD64_POOL_HOST"
    ssh_opts = [
      "-o", "StrictHostKeyChecking=accept-new",
      "-o", "UserKnownHostsFile=/path/to/known_hosts",
      "-i", "/path/to/id_ed25519",
    ]
  }

  registry_auths = [
    {
      address  = "ghcr.io"
      username = "GITHUB_USER_OR_ORG"
      password = "GITHUB_PAT_WITH_PACKAGES_READ"
    },
  ]
}
