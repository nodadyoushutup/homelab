# Copy to CONFIG_DIR/terraform/providers/grafana.tfvars (not committed to the homelab repo).
# Loaded only by terraform/swarm/grafana/config (pipelines/terraform/swarm/grafana/config.sh
# sources scripts/terraform/swarm_grafana_provider_tfvars_env.sh). Not part of the global
# swarm_pipeline shared prefix — avoids provider_config collisions with NPM and other stacks.
# Supplies provider_config.grafana for the Grafana Terraform provider.

provider_config = {
  grafana = {
    url  = "http://__SWARM_NODE_IP__:3000"
    auth = "admin:__GRAFANA_ADMIN_PASSWORD_OR_API_TOKEN__"
  }
}
