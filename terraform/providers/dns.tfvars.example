# Copy to CONFIG_DIR/terraform/providers/dns.tfvars (same directory as docker_swarm.tfvars).
# Do not commit site-specific resolvers to the homelab repo; keep the live file on CONFIG_DIR only.
#
# Required by scripts/terraform/swarm_pipeline.sh (no in-module default).

dns_nameservers = [
  "__YOUR_LAN_DNS__",
  "1.1.1.1",
  "8.8.8.8",
]
