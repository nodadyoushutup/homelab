# Copy to CONFIG_DIR/terraform/providers/docker_arm64_pool.tfvars (not committed).
# Only pipelines/terraform/swarm/gha-runner-arm64/app.sh merges this after docker_arm64.tfvars.
# Sets `swarm_docker_provider_config` for the ARM64 pool host (standalone docker_container, not Swarm).
# Merged last by pipelines/terraform/swarm/gha-runner-arm64/app.sh (replaces docker_arm64.tfvars for this stack).
# Include `docker` (pool SSH host) and `registry_auths` as in docker_arm64.tfvars.

swarm_docker_provider_config = {
  docker = {
    # Example: dedicated Swarm worker with RAM headroom (not the control plane).
    host = "ssh://USER@swarm-wk-0.local"
    ssh_opts = [
      "-o", "StrictHostKeyChecking=accept-new",
      "-o", "ConnectTimeout=15",
      "-o", "ServerAliveInterval=10",
      "-o", "ServerAliveCountMax=3",
      "-o", "UserKnownHostsFile=/path/to/known_hosts",
      "-i", "/path/to/id_ed25519",
    ]
  }

  registry_auths = [
    {
      address  = "ghcr.io"
      username = "GITHUB_USER_OR_ORG"
      password = "GITHUB_PAT_WITH_PACKAGES_READ"
    },
  ]
}
