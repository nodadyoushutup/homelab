# Copy to CONFIG_DIR/terraform/swarm/prometheus-pve-exporter/app.tfvars
#
# 1. Run scripts/swarm/ensure_pve_prometheus_api_token.sh (creates prometheus@pve + API token).
# 2. Add scrape job to CONFIG_DIR/terraform/swarm/prometheus/prometheus.yaml (see outputs).
# 3. Apply this stack, then re-apply prometheus/app so config reloads.
endpoint_host         = "192.168.1.121"
published_port        = 9221
pve_targets           = ["192.168.1.10"]
verify_ssl            = false
disable_config_collector = true

# Password auth (simplest for homelab):
env = {
  PVE_USER       = "root@pam"
  PVE_PASSWORD   = "REPLACE_ME"
  PVE_VERIFY_SSL = "false"
}

# Or API token (see scripts/swarm/ensure_pve_prometheus_api_token.sh):
# env = {
#   PVE_USER        = "prometheus@pve"
#   PVE_TOKEN_NAME  = "monitoring"
#   PVE_TOKEN_VALUE = "REPLACE_WITH_TOKEN_SECRET"
#   PVE_VERIFY_SSL  = "false"
# }

placement = {
  constraints = ['node.labels.role==swarm-wk-0']
  platforms = [
    {
      os           = "linux"
      architecture = "aarch64"
    },
  ]
}
