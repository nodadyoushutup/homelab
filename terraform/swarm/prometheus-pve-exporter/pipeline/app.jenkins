pipeline {
  agent none

  options {
    disableConcurrentBuilds()
  }

  stages {
    stage('Terraform') {
      agent {
        label 'swarm/prometheus-pve-exporter/app'
      }
      steps {
        sh './scripts/terraform/jenkins_stage_runner.sh ./terraform/swarm/prometheus-pve-exporter/pipeline/app.sh'
      }
    }
  }
}
