provider_config = {
  harbor = {
    url      = "http://swarm-cp-0.local:35080"
    username = "admin"
    password = "replace-me"
    insecure = true
  }
}

# Images are published as harbor.example.com/homelab/<image>:<tag> (single Harbor project).
# Terraform always declares project `homelab`; omit `projects` entirely, or list only
# extra projects, or repeat `homelab` here to override defaults (visibility, quotas, etc.).
# To migrate from older per-image Harbor projects, run:
#   scripts/misc/harbor_migrate_to_homelab_project.sh --ensure-project
projects = [
  {
    name                   = "homelab"
    public                 = false
    vulnerability_scanning = true
  },
]

# Optional local users
# users = [
#   {
#     username  = "ci-user"
#     email     = "ci-user@example.com"
#     full_name = "CI User"
#     password  = "replace-me"
#     admin     = false
#   }
# ]

# Optional membership (project_name must exist in projects)
# project_members = [
#   {
#     project_name = "homelab"
#     user_name    = "ci-user"
#     role         = "developer"
#   }
# ]

# Optional robot account example (single Harbor project `homelab`)
# robot_accounts = [
#   {
#     name        = "gha-publish"
#     level       = "system"
#     description = "GitHub Actions publish account for homelab custom images"
#     permissions = [
#       {
#         kind      = "project"
#         namespace = "homelab"
#         access = [
#           { action = "push", resource = "repository" },
#           { action = "pull", resource = "repository" },
#         ]
#       },
#     ]
#   }
# ]

# Optional system config (only applied when enabled)
# manage_system_config = true
# system_config = {
#   robot_name_prefix      = "robot$"
#   robot_token_expiration = 30
# }

# Set to false to leave Harbor's default-seeded `library` project alone.
# Defaults to true: the stack idempotently deletes `library` on every apply
# via the REST API (a null_resource + local-exec; `library` is created by
# Harbor core during initial DB bootstrap and the harbor provider can't
# manage it without an import dance). Deletion fails with HTTP 412 if the
# project still contains repositories.
# delete_default_library = true
