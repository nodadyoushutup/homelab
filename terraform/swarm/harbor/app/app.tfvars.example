# homelab-config: terraform/swarm/harbor/app
#
# Operator-facing Harbor app settings. Component env files and nginx/core configs are
# generated automatically by harbor-prepare (runs inside pipelines/terraform/swarm/harbor/app.sh).

# Docker SSH + optional registry auth: .config/terraform/components/swarm.tfvars
# Swarm DNS nameservers: .config/terraform/components/dns.tfvars

harbor_hostname         = "harbor.example.com"
harbor_admin_password   = "replace-me"
harbor_db_password      = "replace-me"
# Optional when Harbor is published via HTTPS on an edge proxy:
# harbor_external_url = "https://harbor.example.com"

harbor_install_path = "/mnt/eapp/harbor"
harbor_data_path    = "/mnt/eapp/data/harbor"
harbor_log_path     = "/mnt/eapp/log/harbor"

enable_trivy = true

network_name              = "harbor"
proxy_published_port      = 35080
log_syslog_published_port = 1514

# Optional image overrides (defaults are GHCR 0.0.3 digests in variables.tf).
# images = { ... }

placement = {
  constraints = ["node.labels.role==swarm-cp-0"]
  platforms = [
    {
      os           = "linux"
      architecture = "aarch64"
    },
  ]
}
