# Docker SSH + optional registry auth for Harbor component images:
# /mnt/eapp/config/providers/docker.tfvars (`swarm_docker_provider_config`).

# Keep these aligned with the host where Harbor data/config currently live.
harbor_install_path = "/mnt/eapp/harbor-manual/harbor"
harbor_data_path    = "/mnt/eapp/harbor-manual/data"
harbor_log_path     = "/mnt/eapp/harbor-manual/log"

# Option A (recommended): point Terraform runner at env files that already exist.
env_file_paths = {
  db          = "/mnt/eapp/harbor-manual/harbor/common/config/db/env"
  core        = "/mnt/eapp/harbor-manual/harbor/common/config/core/env"
  registryctl = "/mnt/eapp/harbor-manual/harbor/common/config/registryctl/env"
  jobservice  = "/mnt/eapp/harbor-manual/harbor/common/config/jobservice/env"
  trivy       = "/mnt/eapp/harbor-manual/harbor/common/config/trivy-adapter/env"
}

# Option B: provide explicit env maps (overrides env_file_paths for non-empty maps).
# env = {
#   db = {
#     POSTGRES_PASSWORD = "replace-me"
#   }
#   core = {}
#   registryctl = {}
#   jobservice = {}
#   trivy = {}
# }

# Override images if you want different local/custom tags (defaults are GHCR 0.0.1 digests in variables.tf).
# images = {
#   log           = "ghcr.io/nodadyoushutup/harbor-log:0.0.1@sha256:cfcb4497d9c42eb21a91cc92e2b92033809ddaab9f5b3ff32b98af01e0ffcd2b"
#   registry      = "ghcr.io/nodadyoushutup/registry-photon:0.0.1@sha256:c39b686661967449659425b8752756c81dc6697b48595659181e4c2e61c0dbc4"
#   registryctl   = "ghcr.io/nodadyoushutup/harbor-registryctl:0.0.1@sha256:bc42ae9c1b5853717da9adcbd3ff828b2d5b8fc84377aa86417eb63206a1cb7b"
