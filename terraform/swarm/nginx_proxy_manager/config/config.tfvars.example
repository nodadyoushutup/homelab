# Example only — copy to /mnt/eapp/code/homelab/.config/nginx-proxy-manager/config.tfvars (or pass via --tfvars).
# Real files are large; this shows the pieces you add per new hostname.
# To remove NPM entries for retired filesystem/git/ast-grep MCPs only: edit your live tfvars and
# delete matching certificates/proxy_hosts — see docs/workflows/edge-dns-and-nginx-proxy.md (section "Retired standalone code MCPs").

provider_config = {
  nginx_proxy_manager = {
    url          = "http://192.0.2.10:81"
    username     = "admin@example.com"
    password     = "replace-with-npm-password"
    validate_tls = false
  }
}

config = {
  default_certificate_email = "admin@example.com"

  default_dns_challenge = {
    enabled             = true
    provider            = "cloudflare"
    credentials         = "dns_cloudflare_api_token = replace-with-token"
    propagation_seconds = 60
  }

  certificates = [
    {
      name         = "example_app"
      domain_names = ["app.example.com"]
    },
  ]

  proxy_hosts = [
    {
      name           = "example_app_example_com"
      domain_names   = ["app.example.com"]
      scheme         = "http"
      forward_host   = "192.0.2.10"
      forward_port   = 8080
      certificate    = "example_app"
    },
  ]
}
