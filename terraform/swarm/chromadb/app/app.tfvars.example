# Copy to CONFIG_DIR/terraform/swarm/chromadb/app.tfvars (not committed).
# Docker SSH + registry: CONFIG_DIR/terraform/providers/docker_arm64.tfvars (pipeline --docker-tfvars).
#
# Image, published port, and data volume are pinned in main.tf (chromadb/chroma:1.5.9).

dns_nameservers = [
  "192.168.1.1",
  "1.1.1.1",
]

endpoint_host         = "192.168.1.120"
replicas              = 1
placement_constraints = ["node.labels.role==swarm-wk-4"]
platform_architecture = "aarch64"
