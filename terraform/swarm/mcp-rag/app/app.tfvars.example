# Copy to /mnt/eapp/code/homelab/.config/mcp-rag/app.tfvars (or pass via --tfvars).
#
# Docker SSH + registry credentials: /mnt/eapp/code/homelab/.config/terraform/providers/docker_arm64.tfvars
# (`swarm_docker_provider_config`), including Harbor and/or GHCR entries.

image_reference = "harbor.nodadyoushutup.com/homelab/mcp-rag:latest"
published_port  = 9016
endpoint_host   = "192.168.1.120"

placement = {
  constraints = ['node.labels.role==swarm-wk-4']
  platforms = [
    {
      os           = "linux"
      architecture = "aarch64"
    },
  ]
}
