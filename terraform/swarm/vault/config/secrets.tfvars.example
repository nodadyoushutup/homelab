# Colocate Vault KV payloads in the same slice tfvars as the stack (ignored by
# Swarm Terraform but merged by scripts/terraform/vault_merge_config_secrets.py), e.g.
# terraform/swarm/grafana/app.tfvars:

secrets = {
  example_group = {
    example_secret = {
      username = "replace-me"
      password = "replace-me"
    }
  }
}

secret_files = {
  example_group = {
    tls_material = {
      cert_pem = "/mnt/eapp/code/homelab/.config/example_app/tls/cert.pem"
      key_pem  = "/mnt/eapp/code/homelab/.config/example_app/tls/key.pem"
    }
  }
}
