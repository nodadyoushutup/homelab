      "targets": [
        {
          "expr": "sum by (category) (qbit_downloaded{host=~\"$host\", category=~\"$category\"})",
          "legendFormat": "{{category}} downloaded",
          "refId": "A"
        },
        {
          "expr": "sum by (category) (qbit_uploaded{host=~\"$host\", category=~\"$category\"})",
          "legendFormat": "{{category}} uploaded",
          "refId": "B"
        }
      ],
      "title": "Transferred by category",
