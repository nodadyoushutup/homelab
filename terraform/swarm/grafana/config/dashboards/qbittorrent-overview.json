  "title": "qBittorrent Overview",
  "uid": "qbittorrent-overview",
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "host",
        "label": "Instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(qbit_dlspeed, host)",
        "query": "label_values(qbit_dlspeed, host)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "category",
        "label": "Category",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(qbit_dlspeed{host=~\"$host\"}, category)",
        "query": "label_values(qbit_dlspeed{host=~\"$host\"}, category)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
