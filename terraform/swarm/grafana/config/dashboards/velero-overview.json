          "options": {
            "excludeByName": { "Time": true, "Time 1": true, "Time 2": true, "__name__": true, "instance": true, "job": true },
            "renameByName": {
              "Value #A": "Status",
              "Value #B": "Last success",
              "schedule": "Schedule"
            }
          }
        }
      ],
