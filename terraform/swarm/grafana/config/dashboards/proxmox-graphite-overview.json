  "title": "Proxmox (Graphite)",
  "uid": "proxmox-graphite-overview",
  "version": 2,
  "templating": {
    "list": [
      {
        "name": "vm",
        "label": "VM",
        "type": "query",
        "datasource": { "type": "graphite", "uid": "graphite" },
        "definition": "proxmox.qemu.*",
        "query": "proxmox.qemu.*",
        "regex": "/^proxmox\\.qemu\\.([^.]+)/",
        "includeAll": true,
        "allValue": "*",
        "multi": true,
        "refresh": 2,
        "sort": 3,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "node",
        "label": "Node",
        "type": "query",
        "datasource": { "type": "graphite", "uid": "graphite" },
        "definition": "proxmox.storages.*",
        "query": "proxmox.storages.*",
        "regex": "/^proxmox\\.storages\\.([^.]+)/",
        "includeAll": false,
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "skipUrlSync": false,
        "options": [],
        "current": { "selected": true, "text": "pve", "value": "pve" }
      },
      {
        "name": "storage",
        "label": "Storage",
        "type": "query",
        "datasource": { "type": "graphite", "uid": "graphite" },
        "definition": "proxmox.storages.$node.*",
        "query": "proxmox.storages.$node.*",
        "regex": "/^proxmox\\.storages\\.[^.]+\\.([^.]+)/",
        "includeAll": true,
        "allValue": "*",
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "skipUrlSync": false,
        "options": [],
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Virtual machines",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "CPU usage",
      "description": "Guest CPU ratio from Proxmox (0–1).",
      "type": "timeseries",
      "datasource": { "type": "graphite", "uid": "graphite" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "target": "aliasByNode(scale(proxmox.qemu.$vm.cpu, 100), 2)",
          "textEditor": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": ["max", "lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
