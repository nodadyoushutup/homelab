# Copy to /mnt/eapp/code/homelab/.config/mcp-code/app.tfvars (or pass via --tfvars).
# Build/push: `.github/workflows/docker_build_push.yml` → `mcp-code` → GHCR.
#
# Docker SSH + registry auth: /mnt/eapp/code/homelab/.config/terraform/providers/docker_arm64.tfvars
# Private GHCR: PAT with `read:packages`; Harbor: add a second entry under registry_auths there.

image_reference    = "ghcr.io/nodadyoushutup/mcp-code:0.0.2"
published_port     = 18212
endpoint_host      = "192.168.1.120"
# Omit placement to let Swarm schedule without constraints/platforms.
# placement = {
#   constraints = ["node.labels.role==swarm-wk-4"]
#   platforms = [
#     {
#       os           = "linux"
#       architecture = "aarch64"
#     },
#   ]
# }
# Shared docker_arm64.tfvars, dns.tfvars, and nfs.tfvars supply swarm_* inputs (see terraform/providers/*.tfvars.example).
