# Build/push images first (native arm64 recommended): GitHub Actions workflow
# `.github/workflows/docker_build_push.yml` → build_target `rag-engine` (and/or
# `mcp-rag`), target_registry `github`, `both`, or `harbor`; build_platforms
# `arm64` or `both`. Typical refs: `harbor.nodadyoushutup.com/homelab/rag-engine:<version>`
# or `ghcr.io/<owner>/rag-engine:<version>` / `:latest` / `:<version>-arm64`.
#
# Docker SSH host + registry auth (GHCR, Harbor, …) live in
# `/mnt/eapp/code/homelab/.config/terraform/providers/docker_arm64.tfvars` as `swarm_docker_provider_config`.

image_reference     = "harbor.nodadyoushutup.com/homelab/rag-engine:0.0.7"
published_port      = 9015
endpoint_host       = "192.168.1.120"
env_file_path    = "/mnt/eapp/code/homelab/.config/docker/rag.env"
workspace_mount  = "/mnt/eapp/code/homelab"
# swarm_nfs_* — set only in CONFIG_DIR/terraform/providers/nfs.tfvars (merged by swarm_pipeline).

# OpenAI is the default (embedding_provider = "openai"). For Google, set:
# embedding_provider = "google"
# embedding_model    = "gemini-embedding-001"
# openai_embedding_dimensions = "" # optional; only for text-embedding-3* models
#
# If switching provider/model/dimensions, use a new Chroma collection or rebuild
# the existing collection because vector dimensions/model spaces are not compatible.
# chroma_collection = "homelab_openai"

env = {
  RAG_ENGINE_API_KEY = "replace-me"
  # OPENAI_API_KEY     = "sk-..."
}

placement = {
  constraints = ['node.labels.role==swarm-wk-4']
  platforms = [
    {
      os           = "linux"
      architecture = "aarch64"
    },
  ]
}
