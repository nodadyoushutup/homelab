# Build/push images first (native arm64 recommended): GitHub Actions workflow
# `.github/workflows/docker_build_push.yml` → build_target `rag-engine` (and/or
# `mcp-rag`), target_registry `github`, `both`, or `harbor`; build_platforms
# `arm64` or `both`. Typical GHCR refs: `ghcr.io/<owner>/rag-engine:latest` or
# `:<version>` / `:<version>-arm64`. Harbor (if mirrored): mirror path in Harbor.
#
# Private GHCR: add `registry_auth` inside `provider_config` below (same shape as
# chromadb / gha-runner-arm64). Omit `address` to default `ghcr.io`.
#
#   provider_config = { docker = {…}, registry_auth = { username = "…", password = "…" } }

provider_config = {
  docker = {
    host = "ssh://nodadyoushutup@192.168.1.120"
    ssh_opts = [
      "-o", "StrictHostKeyChecking=no",
      "-o", "UserKnownHostsFile=/mnt/eapp/config/.ssh/known_hosts",
      "-i", "/mnt/eapp/config/.ssh/id_ed25519",
    ]
  }

  # registry_auth = { username = "…", password = "…" }
}

image_reference     = "ghcr.io/nodadyoushutup/rag-engine:0.0.6"
published_port      = 9015
endpoint_host       = "192.168.1.120"
env_file_path    = "/mnt/eapp/code/homelab/.secrets/.env"
workspace_mount  = "/mnt/eapp/code/homelab"
# nfs_server      = "192.168.1.100"
# nfs_code_device = ":/mnt/eapp/code"

# Google remains the default. For OpenAI, set:
# embedding_provider = "openai"
# embedding_model    = "text-embedding-3-small"
# openai_embedding_dimensions = "" # optional; only for text-embedding-3* models
#
# If switching provider/model/dimensions, use a new Chroma collection or rebuild
# the existing collection because vector dimensions/model spaces are not compatible.
# chroma_collection = "homelab_openai"

env = {
  RAG_ENGINE_API_KEY = "replace-me"
  # OPENAI_API_KEY     = "sk-..."
}
