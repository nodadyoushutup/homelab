{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dockerfile": {
    "managerFilePatterns": [
      "/(^|/)applications/jenkins-controller/Dockerfile$/",
      "/(^|/)applications/jenkins-agent/Dockerfile$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/^kubernetes/.+\\.ya?ml$/"
    ]
  },
  "hostRules": [
    {
      "matchHost": "https://ghcr.io",
      "hostType": "docker",
      "username": "nodadyoushutup",
      "password": "{{ secrets.GitHubPAT }}"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "minio/minio"
      ],
      "enabled": false
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "lscr.io/linuxserver/qbittorrent"
      ],
      "enabled": false
    }
  ]
}
