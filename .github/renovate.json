{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dockerfile": {
    "managerFilePatterns": [
      "/(^|/)applications/jenkins/controller/Dockerfile$/",
      "/(^|/)applications/jenkins/agent/Dockerfile$/"
    ]
  },
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "minio/minio"
      ],
      "enabled": false
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "jc21/nginx-proxy-manager"
      ],
      "allowedVersions": "!/^2\\.13\\.[0-6](?:$|-)/"
    }
  ]
}
