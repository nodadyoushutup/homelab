# Copy to app.tfvars (gitignored) and apply to Vault path k8s/velero.
# ExternalSecret velero-s3-credentials reads these properties hourly.
#
#   vault kv put k8s/velero \
#     aws_access_key_id="SERVICE_ACCOUNT_ACCESS_KEY" \
#     aws_secret_access_key="SERVICE_ACCOUNT_SECRET_KEY"
#
# MinIO S3 API (not Console :9001): http://192.168.1.25:9000
# One bucket per app (radarr, sonarr, …) plus velero-misc for the default BSL.
# Velero service account needs s3:* on those buckets (or use root keys for homelab).

aws_access_key_id     = "REPLACE_ME"
aws_secret_access_key = "REPLACE_ME"
