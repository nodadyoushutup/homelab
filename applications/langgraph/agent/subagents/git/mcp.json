{
  "mcpServers": {
    "mcp-rag": {
      "transport": "http",
      "url": "https://mcp.rag.nodadyoushutup.com/mcp",
      "url_from_env": "HOMELAB_MCP_RAG_URL",
      "x_api_key_from_env": "MCP_RAG_API_KEY"
    },
    "mcp-git": {
      "transport": "http",
      "url": "https://mcp.git.nodadyoushutup.com/mcp",
      "url_from_env": "HOMELAB_MCP_GIT_URL",
      "headers": {
        "x-workspace-root": "/mnt/eapp/code/homelab"
      }
    },
    "mcp-github": {
      "transport": "http",
      "url": "https://mcp.github.nodadyoushutup.com/mcp",
      "url_from_env": "HOMELAB_MCP_GITHUB_URL"
    }
  }
}
