# Repo or org URL, e.g. https://github.com/OWNER/REPO or https://github.com/ORG
GH_RUNNER_URL=

# Registration token generated from GitHub UI/API.
GH_RUNNER_TOKEN=

# Optional runtime tuning.
GH_RUNNER_NAME=homelab-gha-runner
GH_RUNNER_LABELS=self-hosted,linux,homelab
GH_RUNNER_WORKDIR=_work
GH_RUNNER_EPHEMERAL=false
GH_RUNNER_DISABLEUPDATE=true

# Optional: token for removing runner registration on container shutdown.
GH_RUNNER_REMOVE_TOKEN=

# Optional build override.
RUNNER_VERSION=2.326.0
