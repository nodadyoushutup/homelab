# homelab-config: terraform/components/swarm/graylog/app
# Graylog app stage (admin bootstrap). Generated 2026-05-16T19:53:01-04:00.
# Self-contained slice tfvars (provider/DNS/NFS inlined; no shared swarm/dns/nfs var-files).

# Docker provider comes from the shared catalog (config-id
# terraform/providers/docker); the pipeline passes docker.tfvars as an extra
# -var-file. This slice just selects a machine (and reuses shared registry_auths).
docker_machine = "swarm-cp-0"

dns_nameservers = [
  "",
  "",
  "",
]

env = {
  GRAYLOG_PASSWORD_SECRET    = ""
  GRAYLOG_ROOT_PASSWORD_SHA2 = ""
  GRAYLOG_HTTP_EXTERNAL_URI  = ""
  GRAYLOG_MONGODB_URI        = ""
}

published_port_ui         = 9002
published_port_syslog_tcp = 5514
published_port_gelf_tcp   = 12201

placement = {
  constraints = [""]
  platforms = [
    {
      os           = ""
      architecture = ""
    },
  ]
}
