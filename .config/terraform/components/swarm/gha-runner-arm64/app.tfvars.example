# homelab-config: terraform/components/swarm/gha-runner-arm64/app
# ARM64 GitHub Actions runner pool: standalone `docker_container` on the pool host.
# Provider/DNS/NFS inputs are self-contained in this slice tfvars.
# GH_RUNNER_NAME is injected per replica in main.tf.
# Self-contained slice tfvars (pool docker provider/DNS/NFS inlined; no shared runners/{amd64,arm64} or swarm dns/nfs var-files).

# Docker provider comes from the shared catalog (config-id
# terraform/providers/docker); the pipeline passes docker.tfvars as an extra
# -var-file. This slice just selects a machine (and reuses shared registry_auths).
docker_machine = "swarm-wk-1"

dns_nameservers = [
  "",
  "",
  "",
]

# NFS comes from the shared catalog (config-id terraform/nfs); the pipeline passes
# nfs.tfvars as an extra -var-file. This slice just selects a share + mount point.
nfs_share        = "code"
nfs_subpath      = "/homelab"
nfs_mount_target = "/mnt/eapp/code/homelab"

replicas = 4

env = {
  GH_RUNNER_URL            = ""
  GH_RUNNER_TOKEN          = ""
  GH_RUNNER_ACCESS_TOKEN   = ""
  GH_RUNNER_LABELS         = ""
  GH_RUNNER_WORKDIR        = ""
  GH_RUNNER_EPHEMERAL      = ""
  GH_RUNNER_DISABLEUPDATE  = ""
  RUNNER_ALLOW_RUNASROOT   = ""
  GHA_ENGINE_BUILD_TMP_PARENT  = ""
  PACKER_LOG               = ""
}
