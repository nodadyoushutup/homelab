# homelab-config: terraform/components/swarm/cloud-image-repository/app
# Self-contained slice tfvars (provider/DNS/NFS inlined; no shared swarm/dns/nfs var-files).

# Docker provider comes from the shared catalog (config-id
# terraform/providers/docker); the pipeline passes docker.tfvars as an extra
# -var-file. This slice just selects a machine (and reuses shared registry_auths).
docker_machine = "swarm-cp-0"

dns_nameservers = [
  "",
  "",
  "",
]

placement = {
  constraints = [""]
  platforms = [
    {
      os           = ""
      architecture = ""
    },
  ]
}

# NFS backing the served /data directory (data/packer). Comes from the shared
# catalog (config-id terraform/nfs); the pipeline passes nfs.tfvars as an extra
# -var-file. This slice selects a share + the sub-path that holds Packer output.
# The served container path is fixed at /data (see the app locals).
nfs_share   = "code"
nfs_subpath = "/homelab/data/packer"
