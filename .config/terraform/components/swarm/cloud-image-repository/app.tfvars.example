# homelab-config: terraform/components/swarm/cloud-image-repository/app
# Self-contained slice tfvars (provider/DNS/NFS inlined; no shared swarm/dns/nfs var-files).

swarm_docker_provider_config = {
  docker = {
    host = ""
    ssh_opts = [
      "", "",
      "", "",
      "", "",
    ]
  }

  registry_auths = [
    {
      address  = ""
      username = ""
      password = ""
    },
    {
      address  = ""
      username = ""
      password = ""
    },
  ]
}

dns_nameservers = [
  "",
  "",
  "",
]

placement = {
  constraints = [""]
  platforms = [
    {
      os           = ""
      architecture = ""
    },
  ]
}

# NFS export backing the served /data directory (data/packer). No local volume.
# driver_options are the Docker local-driver NFS mount opts, e.g.
#   type   = "nfs"
#   device = ":/path/to/repo/data/packer"
#   o      = "addr=<nfs-server-ip>,nfsvers=4.2,rw"
nfs = {
  driver_options = {
    type   = ""
    device = ""
    o      = ""
  }
}
