# homelab-config: terraform/components/swarm/jenkins-controller/app
# Jenkins controller stage tfvars.
# Self-contained slice tfvars (provider/DNS/NFS inlined; no shared swarm/dns/nfs var-files).

# Docker provider comes from the shared catalog (config-id
# terraform/providers/docker); the pipeline passes docker.tfvars as an extra
# -var-file. This slice just selects a machine (and reuses shared registry_auths).
docker_machine = "swarm-cp-0"

dns_nameservers = [
  "",
  "",
  "",
]

# NFS comes from the shared catalog (config-id terraform/nfs); the pipeline passes
# nfs.tfvars as an extra -var-file. This slice just selects a share + mount point.
nfs_share        = "code"
nfs_subpath      = "/homelab"
nfs_mount_target = "/mnt/eapp/code/homelab"
controller_published_port = 18094
agent_published_port      = 50000

casc_config_path = ""
shared_tfvars_volume_name = ""

mounts = []

env = {
  SECRETS_DIR            = ""
  JENKINS_ADMIN_USERNAME = ""
  JENKINS_ADMIN_PASSWORD = ""
  PLUGINS_FORCE_UPGRADE  = ""
}

placement = {
  constraints = [""]
  platforms = [
    {
      os           = ""
      architecture = ""
    },
  ]
}
