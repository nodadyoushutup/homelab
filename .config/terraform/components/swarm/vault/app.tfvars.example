# homelab-config: terraform/components/swarm/vault/app
# Self-contained slice tfvars (provider/DNS/NFS inlined; no shared swarm/dns/nfs var-files).

# Docker provider comes from the shared catalog (config-id
# terraform/providers/docker); the pipeline passes docker.tfvars as an extra
# -var-file. This slice just selects a machine (and reuses shared registry_auths).
docker_machine = "swarm-cp-0"

dns_nameservers = [
  "",
  "",
  "",
]

placement = {
  constraints = [""]
  platforms = [{
    os           = ""
    architecture = ""
  }]
}

api_addr     = ""
cluster_addr = ""
raft_node_id = ""
published_port = 8200
