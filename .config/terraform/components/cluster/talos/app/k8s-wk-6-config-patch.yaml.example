machine:
  install:
    disk: ""
    image: ""
    extensions:
      - image: ghcr.io/siderolabs/iscsi-tools:v0.2.0
  network:
    interfaces:
      - interface: ens18
        dhcp: false
        addresses:
          - 192.168.1.208/24
        routes:
          - network: 0.0.0.0/0
            gateway: 192.168.1.1
