# homelab-config: terraform/components/cluster/proxmox/app
# Proxmox cloud images and VMs (machines), managed by the homelab-config web app
# (config-id terraform/components/cluster/proxmox/app). Provider login
# credentials are separate (config-id terraform/providers/proxmox ->
# .config/terraform/providers/proxmox.tfvars) and passed as an extra -var-file.
#
# Machines reference images by key (disk.image / cdrom.image). Constant fields
# (bios, machine, cpu type, efi disk, network bridge/model, ...) default in the
# slice locals.tf, so entries only need what differs. Cloud-init user/network
# data are absolute host file paths.

proxmox_images = {
  "ubuntu_24" = {
    file_name = "ubuntu-24.04-amd64.img"
    url       = "https://example.com/ubuntu-24.04-amd64.qcow2"
  }
}

proxmox_machines = {
  "example-vm" = {
    vm_id  = 2201
    memory = 8192

    disk = {
      size  = 20
      image = "ubuntu_24"
    }

    initialization = {
      interface           = "ide0"
      user_config_path    = "/abs/path/example-vm-user-config.yaml"
      network_config_path = "/abs/path/example-vm-network-config.yaml"
    }

    network = {
      mac_address = "BC:24:11:00:00:01"
    }
  }
}
