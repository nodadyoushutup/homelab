version: v1alpha1
debug: false
persist: true
machine:
    type: worker
    token: 9w9rxd.j6vyl4hj1ib9jgdp
    ca:
        crt: 
        key: ""
    certSANs: []
    kubelet:
        image: ghcr.io/siderolabs/kubelet:v1.35.0
        defaultRuntimeSeccompProfileEnabled: true
        disableManifestsDirectory: true
    network:
        interfaces:
            - interface: ens18
              addresses:
                - 192.168.1.205/24
              routes:
                - network: 0.0.0.0/0
                  gateway: 192.168.1.1
              dhcp: false
    install:
        disk: /dev/sda
        image: factory.talos.dev/installer/eda6c02d94377f983da3aa0c8a98c58dc6b2b9341ec42512161eb7661acb526d:v1.12.4
        wipe: false
        grubUseUKICmdline: true
    features:
        diskQuotaSupport: true
        kubePrism:
            enabled: true
            port: 7445
        hostDNS:
            enabled: true
            forwardKubeDNSToHost: true
cluster:
    id: VbI7pURSCRnp2s89uzF4Z3KaENCP1i-9c8y-ehry0bk=
    secret: 6kStJly+rN3fdhRlDn37EYL9FiK+k93oG+sXXVJsMWU=
    controlPlane:
        endpoint: https://192.168.1.201:6443
    clusterName: homelab
    network:
        dnsDomain: cluster.local
        podSubnets:
            - 10.244.0.0/16
        serviceSubnets:
            - 10.96.0.0/12
    token: u4oa8q.nslb4gekrv8ldf4i
    ca:
        crt: 
        key: ""
    discovery:
        enabled: true
        registries:
            kubernetes:
                disabled: true
            service: {}
