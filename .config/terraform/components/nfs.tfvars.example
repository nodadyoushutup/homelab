# Copy to nfs.tfvars beside this file (not committed; keep secrets local).
# First line of the live file: # homelab-config: terraform/components/nfs
# Default CONFIG_DIR / TFVARS_HOME_DIR is <homelab>/.config (see scripts/terraform/load_root_env.sh).
#
# Required by scripts/terraform/swarm_pipeline.sh (merged after dns.tfvars; no in-module defaults).
#
#   nfs.target           → container mount path
#   nfs.driver_options   → Docker local-volume driver_opts (type, device, o)

nfs = {
  target = "/mnt/eapp/code/homelab"

  driver_options = {
    type   = "nfs"
    device = ":/mnt/eapp/code/homelab"
    o      = "addr=__YOUR_NFS_HOST__,nfsvers=4.2,rw,soft,timeo=600,retrans=2"
  }
}
