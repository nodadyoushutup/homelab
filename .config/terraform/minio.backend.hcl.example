# homelab-config: terraform/minio.backend
# Terraform S3 backend configuration for MinIO.
# MinIO on swarm-cp-0 (Docker); reachable as swarm-cp-0.local from the LAN.
bucket = ""
region = ""
# access_key/secret_key auto-populate when MinIO is initialized by bootstrap.
access_key = ""
secret_key = ""

endpoints = { s3 = "" }

skip_credentials_validation = true
skip_metadata_api_check     = true
skip_requesting_account_id  = true
use_path_style              = true
