# Copy to mcp.env — mcp-rag-dev, langgraph-dev (MCP client URLs).
#
# Compose DNS (homelab-dev network only):
HOMELAB_MCP_RAG_URL=http://mcp-rag-dev:8080/mcp
# GitHub / Atlassian MCP are not in this compose file — Swarm LAN ports:
HOMELAB_MCP_GITHUB_URL=http://192.168.1.120:18208/mcp
HOMELAB_MCP_ATLASSIAN_URL=http://192.168.1.120:18200/mcp
#
# Host-only `langgraph dev`: use published ports, e.g.
# HOMELAB_MCP_RAG_URL=http://127.0.0.1:9016/mcp
#
# HTTPS MCP auth — must match the URL LangGraph calls (mcp.json x_api_key_from_env).
MCP_RAG_API_KEY=

# agentmemory remote MCP (Cursor global ~/.cursor/mcp.json)
MCP_AGENTMEMORY_API_KEY=
