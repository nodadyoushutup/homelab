# Copy to mcp.env — MCP client URLs for local and Swarm tools.
#
# GitHub / Atlassian MCP are not in this compose file — Swarm LAN ports:
HOMELAB_MCP_GITHUB_URL=http://192.168.1.120:18208/mcp
HOMELAB_MCP_ATLASSIAN_URL=http://192.168.1.120:18200/mcp

# agentmemory remote MCP (Cursor global ~/.cursor/mcp.json)
MCP_AGENTMEMORY_API_KEY=
