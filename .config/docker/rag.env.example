# Copy to rag.env — rag-engine-dev, mcp-rag-dev, git hooks, rag_backfill.sh.
# Swarm rag-engine Terraform reads this file only — duplicate OPENAI_API_KEY here if needed.
#
# RAG_EMBEDDING_PROVIDER=openai
# RAG_EMBEDDING_MODEL=
# RAG_OPENAI_EMBEDDING_DIMENSIONS=
# RAG_OPENAI_EMBED_BATCH_SIZE=128
# RAG_OPENAI_TIMEOUT_SEC=
# VOYAGE_API_KEY=
# RAG_VOYAGE_BASE_URL=
# RAG_ANTHROPIC_EMBEDDING_DIMENSIONS=
# RAG_ANTHROPIC_EMBED_BATCH_SIZE=128
# RAG_ANTHROPIC_TIMEOUT_SEC=

# Swarm Chroma on overlay; Compose overrides host/port for rag-engine-dev (see compose file).
# RAG_CHROMA_HOSTNAME=chromadb:8000  # host:port; port defaults to 8000
# RAG_CHROMA_COLLECTION=homelab
# RAG_CHROMA_HTTP_MAX_RETRIES=6
# RAG_CHROMA_HTTP_BASE_DELAY_SEC=1.0
# RAG_CHROMA_HTTP_MAX_DELAY_SEC=60.0
# RAG_CHROMA_ADD_BATCH_SIZE=0
# RAG_CHROMA_LIST_BATCH=5000
# RAG_MEMORY_EPISODIC_COLLECTION=memories_episodic
# RAG_MEMORY_DECLARATIVE_COLLECTION=memories_declarative

RAG_ENGINE_API_KEY=
# Git hooks / host scripts (no trailing slash). mcp-rag-dev uses http://rag-engine-dev:8080 in compose.
# RAG_ENGINE_BASE_URL=https://rag-engine.nodadyoushutup.com
# RAG_BACKFILL_HTTP_TIMEOUT_SEC=86400
# RAG_HOOK_INCLUDE_PREFIXES=
# RAG_HOOK_HTTP_TIMEOUT_SEC=300
# RAG_ALLOWED_PATH_PREFIXES=
# RAG_EXCLUDE_PATH_SEGMENTS=  # optional; defaults in applications/rag-engine/src/ingest/path_rules.py
# RAG_EXCLUDE_FILE_SUFFIXES=  # optional; defaults in applications/rag-engine/src/ingest/path_rules.py
