# Copy to minio.env — docker/docker-compose.minio.yaml, scripts/install/velero.sh
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_REGION_NAME=us-east-1
MINIO_PROMETHEUS_AUTH_TYPE=public
MINIO_LOG_LEVEL=debug
# Bootstrap-only: SSH host (or user@host) that bootstrap deploys MinIO onto via
# docker compose. Left blank, bootstrap prompts (default swarm-cp-0.local) and
# writes the answer back here. Not injected into the MinIO container.
MINIO_HOSTNAME=swarm-cp-0.local
