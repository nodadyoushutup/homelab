# Copy to langgraph.env — langgraph-dev (plus shared.env + postgres.env + mcp.env).
# Optional model overrides (defaults are openai:gpt-5.4 in code)
# SUPERVISOR_MODEL=
# CODE_MODEL=
# JIRA_MODEL=
# TECH_LEAD_MODEL=
# GITHUB_MODEL=

CREATE_ISSUE_DEFAULT_PROJECT=HOME

# Optional tracing
# LANGSMITH_TRACING=false

# Transient 502 / network during agent process startup: MCP tool bootstrap retries.
# HOMELAB_MCP_BOOTSTRAP_RETRIES=3
# HOMELAB_MCP_BOOTSTRAP_RETRY_DELAY_SEC=2

# Break-glass: disable LangGraph RAG-before-code and read-before-write middleware (not recommended).
# HOMELAB_DISABLE_WORKFLOW_GATES=1

# Optional repository root overrides (Compose sets these in docker-compose.langgraph.yml).
# CODE_REPOSITORY_ROOT=
# TECH_LEAD_REPOSITORY_ROOT=

# Override dotenv directory (default <repo>/.config/docker); merged_settings loads all *.env in order.
# HOMELAB_CONFIG_ENV_DIR=/mnt/eapp/code/homelab/.config/docker
