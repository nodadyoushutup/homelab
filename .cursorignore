# =============================================================================
# IDE & agent tooling
# =============================================================================
# This repo tracks a few shared defaults; ignore everything else under these dirs.
# Tracked: .cursor/mcp.json, .codex/config.toml, .vscode/homelab.code-workspace

.cursor/
.codex/
.vscode

# Archived repo docs / Cursor config — do not index or treat as live agents/rules
.old/

.idea/
.fleet/
.zed/
.claude/
.continue/
.specstory/

