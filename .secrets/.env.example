# Copy to `.secrets/.env` in this directory and fill in values.
# Single local dotenv for this repo: LangGraph, Docker Compose dev stack, optional MinIO
# (`docker/docker-compose.minio.yaml`), Swarm/terraform pipeline env (`scripts/terraform/load_root_env.sh`),
# Argo CD installer (`scripts/install/argocd.sh`), and tooling that sets HOMELAB_SECRETS_ENV
# or relies on the default path.
# Do not use applications/langgraph/agent/.env — that path is not loaded by this repo.

# --- Terraform tfvars layout (pipelines + scripts/terraform/*) ---
# Leave empty to use <repo>/.config (minio.backend.hcl, terraform/** tfvars, kubernetes/**).
# Do not point at legacy /mnt/eapp/config after the .secrets migration — that path no longer holds tfvars.
CONFIG_DIR=

# --- Argo CD installer (`scripts/install/argocd.sh`) ---
ARGOCD_NAMESPACE=argocd
ARGOCD_MANIFEST_URL=https://raw.githubusercontent.com/argoproj/argo-cd/stable/manifests/install.yaml
ARGOCD_ADMIN_USERNAME=
ARGOCD_ADMIN_PASSWORD=
ARGOCD_SERVER_EXPOSURE_MODE=ClusterIP
ARGOCD_SERVER_HTTP_NODEPORT=30080
ARGOCD_SERVER_HTTPS_NODEPORT=30443
ARGOCD_SERVER_LOADBALANCER_IP=
ARGOCD_SERVER_LOADBALANCER_CLASS=
ARGOCD_GITOPS_APPSET_NAME=homelab-addons
ARGOCD_GITOPS_REPO_URL=git@github.com:nodadyoushutup/homelab.git
ARGOCD_GITOPS_REPO_REVISION=HEAD
ARGOCD_GITOPS_APPS_FILE=
ARGOCD_GITOPS_ROOT_APP_NAME=argocd-bootstrap
ARGOCD_GITOPS_ROOT_APP_FILE=
ARGOCD_GITOPS_REPO_SECRET_NAME=homelab-gitops-repo
ARGOCD_GITOPS_REPO_USERNAME=
ARGOCD_GITOPS_REPO_PASSWORD=
ARGOCD_GITOPS_REPO_SSH_PRIVATE_KEY=

# --- Docker Compose: `docker/docker-compose.yml` (homelab-dev stack) ---
# Run from repo root: docker compose -f docker/docker-compose.yml --env-file .secrets/.env up -d
# This file is passed as `env_file` into langgraph-dev, rag-engine-dev, mcp-rag-dev, mcp-code-dev, and
# langgraph-postgres. Compose also interpolates `${VAR:-default}` from this file when you pass
# `--env-file .secrets/.env`, so LangGraph `mcp.json` `url_from_env` targets resolve inside containers
# without per-environment JSON edits.
#
# MCP URLs for services on this Compose network (Compose DNS — valid only between homelab-dev containers):
HOMELAB_MCP_RAG_URL=http://mcp-rag-dev:8080/mcp
HOMELAB_MCP_CODE_URL=http://mcp-code-dev:8100/mcp
# GitHub / Atlassian MCP are not built into this compose file; use Swarm published ports on your LAN
# (defaults match `terraform/swarm/mcp-github` / `terraform/swarm/mcp-atlassian` tfvars examples).
HOMELAB_MCP_GITHUB_URL=http://192.168.1.120:18208/mcp
HOMELAB_MCP_ATLASSIAN_URL=http://192.168.1.120:18200/mcp
#
# Host directory bind-mounted at `/mnt/eapp/code/homelab` inside mcp-code-dev and langgraph-dev:
HOMELAB_MCP_CODE_HOST_MOUNT=/mnt/eapp/code/homelab
# LangGraph sets HOMELAB_REPO_ROOT=/app in Docker so `default_repo_root()` would mis-locate `.secrets`;
# point `merged_settings` / `secrets_env_path()` at the mounted repo copy (override if your mount differs):
HOMELAB_SECRETS_ENV=/mnt/eapp/code/homelab/.secrets/.env
#
# Swarm / K8s LangGraph: use public `https://mcp.*` URLs (or omit `HOMELAB_MCP_*` to fall back to mcp.json
# defaults). Terraform continues to inject task env from tfvars for Swarm services — this block is the
# canonical **local Docker dev** orientation.
#
# Host-only `langgraph dev` (no LangGraph container): MCP hostnames above do not resolve on the host;
# use published ports instead, e.g. HOMELAB_MCP_RAG_URL=http://127.0.0.1:9016/mcp and
# HOMELAB_MCP_CODE_URL=http://127.0.0.1:9017/mcp while homelab-dev MCP services are up.

# --- MinIO (`docker/docker-compose.minio.yaml`) ---
# From docker/: docker compose -f docker-compose.minio.yaml up -d
# (compose loads this file via `env_file`; only MINIO_* keys are required for MinIO.)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_REGION_NAME=us-east-1
MINIO_PROMETHEUS_AUTH_TYPE=public
MINIO_LOG_LEVEL=debug

OPENAI_API_KEY=

# qBittorrent Web UI (Swarm qbittorrent-metrics-exporter; same password as Kubernetes instances)
# QBITTORRENT_PASSWORD=

# Harbor (docker login + Swarm image pulls). Required to run scripts/agents/publish_mcp_code_harbor.sh
# HARBOR_USERNAME=
# HARBOR_PASSWORD=

# Optional model overrides (defaults are openai:gpt-5.4 in code)
# SUPERVISOR_MODEL=
# CODE_MODEL=
# JIRA_MODEL=
# TECH_LEAD_MODEL=
# GITHUB_MODEL=

# Transient 502 / network during agent process startup: retries for MCP tool bootstrap (defaults: 3 tries, 2s apart).
# HOMELAB_MCP_BOOTSTRAP_RETRIES=3
# HOMELAB_MCP_BOOTSTRAP_RETRY_DELAY_SEC=2

# Parallel Jira/agent lanes: each thread can override mcp-code URL + repo root via
# RunnableConfig["configurable"] (homelab_mcp_code_url, homelab_code_repository_root).
# Script: scripts/agents/homelab_jira_issue_worktree.sh — see docs/workflows/mcp-code-worktrees-and-multi-agent.md

# Optional Code agent repository root override (defaults to this repo root)
# CODE_REPOSITORY_ROOT=

# Optional Tech Lead agent repository root override (defaults to this repo root)
# TECH_LEAD_REPOSITORY_ROOT=

# Break-glass: disable LangGraph RAG-before-code and read-before-write middleware (not recommended).
# HOMELAB_DISABLE_WORKFLOW_GATES=1

CREATE_ISSUE_DEFAULT_PROJECT=HOME

# HTTPS MCP: must match whatever URL `HOMELAB_MCP_RAG_URL` targets when mcp-rag enforces auth.
# Used by LangGraph `mcp.json` (`x_api_key_from_env`), Codex `env_http_headers`, and Cursor MCP config.
MCP_RAG_API_KEY=

# Optional RAG engine embedding provider. Google remains the default.
# For OpenAI, set RAG_EMBEDDING_PROVIDER=openai and OPENAI_API_KEY above.
# For anthropic (Claude ecosystem: Voyage embeddings API), set RAG_EMBEDDING_PROVIDER=anthropic
# and VOYAGE_API_KEY (Bearer token for https://api.voyageai.com/v1/embeddings).
# RAG_EMBEDDING_PROVIDER=google
# RAG_EMBEDDING_MODEL=
# RAG_OPENAI_EMBEDDING_DIMENSIONS=
# RAG_OPENAI_EMBED_BATCH_SIZE=128
# RAG_OPENAI_TIMEOUT_SEC=
# VOYAGE_API_KEY=
# RAG_VOYAGE_BASE_URL=
# RAG_ANTHROPIC_EMBEDDING_DIMENSIONS=
# RAG_ANTHROPIC_EMBED_BATCH_SIZE=128
# RAG_ANTHROPIC_TIMEOUT_SEC=

# --- RAG engine ↔ Chroma (HTTP client; same vars as terraform/swarm/rag-engine) ---
# Swarm: `RAG_CHROMA_HOST=chromadb` on the overlay (see tfvars). Docker `rag-engine-dev` overrides
# Chroma to `HOMELAB_DEV_CHROMA_HOST` / `HOMELAB_DEV_CHROMA_PORT` in compose (defaults 192.168.1.120:8000)
# so a Swarm-only hostname in this file does not break local engine containers. Override Chroma here
# only for host-native rag-engine or non-default LAN layouts.
# RAG_CHROMA_HOST=chromadb
# RAG_CHROMA_PORT=8000
# RAG_CHROMA_COLLECTION=homelab
# Optional tuning (defaults are fine for most setups):
# RAG_CHROMA_HTTP_MAX_RETRIES=6
# RAG_CHROMA_HTTP_BASE_DELAY_SEC=1.0
# RAG_CHROMA_HTTP_MAX_DELAY_SEC=60.0
# RAG_CHROMA_ADD_BATCH_SIZE=0
# RAG_CHROMA_LIST_BATCH=5000
# Long-term memory collections (same Chroma server as the corpus collection):
# RAG_MEMORY_EPISODIC_COLLECTION=memories_episodic
# RAG_MEMORY_DECLARATIVE_COLLECTION=memories_declarative
# Shared secret for rag-engine HTTP (query, embed, memory). Set for any non-local client.
# RAG_ENGINE_API_KEY=
# Base URL for git hooks / host scripts hitting rag-engine HTTP (not used by `mcp-rag-dev`, which forces
# `RAG_ENGINE_BASE_URL=http://rag-engine-dev:8080` in compose). No trailing slash.
# RAG_ENGINE_BASE_URL=https://rag-engine.nodadyoushutup.com
# scripts/misc/rag_backfill.sh (HTTP mode) timeout for POST /v1/backfill (default 86400).
# RAG_BACKFILL_HTTP_TIMEOUT_SEC=86400
# Optional: stricter hook subset than RAG_ALLOWED_PATH_PREFIXES (defaults to same list).
# RAG_HOOK_INCLUDE_PREFIXES=
# Optional: embed-commit timeout seconds (default 300).
# RAG_HOOK_HTTP_TIMEOUT_SEC=300

# LangGraph Docker dev Postgres checkpoint storage.
POSTGRES_DB=langgraph
POSTGRES_USER=langgraph
POSTGRES_PASSWORD=langgraph
POSTGRES_URI=postgresql://langgraph:langgraph@langgraph-postgres:5432/langgraph?sslmode=disable

# Optional tracing
# LANGSMITH_TRACING=false
