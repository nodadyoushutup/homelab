# Copy to `.secrets/.env` at this same directory and fill in values.
# Single source of truth for LangGraph keys and related homelab dev secrets.
# Used by: applications/langgraph (Python merged_settings + agent_server.sh),
# docker compose `langgraph-dev` (env_file), and tooling that sets
# HOMELAB_SECRETS_ENV or relies on the default path.
# Do not use applications/langgraph/agent/.env — that path is not loaded by this repo.

OPENAI_API_KEY=

# Optional model overrides (defaults are openai:gpt-5.4 in code)
# SUPERVISOR_MODEL=
# CODE_MODEL=
# JIRA_MODEL=

CREATE_ISSUE_DEFAULT_PROJECT=HLAB

# Optional tracing
# LANGSMITH_TRACING=false
